# NCBI E-Utilities API key (required for PubMed Evidence feature)
# Get yours at https://www.ncbi.nlm.nih.gov/account/settings/
# Without a key: 3 req/s rate limit.
# With a key: 10 req/s rate limit.
NCBI_API_KEY=your_ncbi_api_key_here

# Email registered with NCBI (required by Entrez)
NCBI_EMAIL=your.email@example.com

# Callback auth (existing)
ANALYSIS_SERVICE_API_KEY=your_analysis_service_key_here
